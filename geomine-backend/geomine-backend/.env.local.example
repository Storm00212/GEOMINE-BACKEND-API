# Neon Postgres connection string (used by the pg Pool in lib/db.ts)
DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# JWT signing secret for access tokens
JWT_SECRET=change-me-in-production

# Comma-separated list of origins allowed to call this API. Include both your
# local frontend dev URL and your deployed frontend URL.
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
